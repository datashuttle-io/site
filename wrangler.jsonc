{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "datashuttle-site",
  "compatibility_date": "2026-05-15",
  "main": "worker/index.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
